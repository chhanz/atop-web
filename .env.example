# atop-web LLM provider settings (example)
# Copy this file to .env and edit values. .env is gitignored.
#
# Provider options: none | bedrock | ollama | openai | anthropic | gemini
# Currently implemented: none, bedrock. Others are skeleton stubs.

LLM_PROVIDER=none

# --- Bedrock settings (when LLM_PROVIDER=bedrock) ---
AWS_REGION=us-east-1
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6

# --- AWS credentials ---
# Leave empty to use EC2 instance profile / IMDSv2 (recommended on EC2).
# For non-EC2 users: uncomment and set below.
#
# Long-lived IAM user keys:
#   AWS_ACCESS_KEY_ID=AKIA....
#   AWS_SECRET_ACCESS_KEY=....
#
# STS temporary credentials (SSO, AssumeRole):
#   AWS_ACCESS_KEY_ID=ASIA....
#   AWS_SECRET_ACCESS_KEY=....
#   AWS_SESSION_TOKEN=....
